# LLM Provider Configuration
LLM_PROVIDER=openai  # or 'azure'

# OpenAI Configuration
OPENAI_API_KEY=your-openai-api-key-here

# Azure OpenAI Configuration
AZURE_API_KEY=your-azure-api-key-here
AZURE_API_BASE=https://your-resource.openai.azure.com/
AZURE_API_VERSION=2024-02-15-preview
AZURE_DEPLOYMENT=your-deployment-name

# LLM Configuration
LLM_MODEL=gpt-4o-mini
LLM_TEMPERATURE=0.1
LLM_MAX_RETRIES=3
LLM_TIMEOUT=60

# Evaluation Configuration
EVAL_BATCH_SIZE=10
EVAL_OUTPUT_DIR=output
EVAL_SAVE_INTERMEDIATE=true

# Logging Configuration
LOG_LEVEL=INFO

# Instructions:
# 1. Copy this file to .env: cp env.example .env
# 2. Edit .env and configure your LLM provider:
#    - For OpenAI: Set OPENAI_API_KEY and LLM_PROVIDER=openai
#    - For Azure: Set AZURE_API_KEY, AZURE_API_BASE, AZURE_DEPLOYMENT and LLM_PROVIDER=azure
# 3. Run: uv run python run_llm_evaluation.py
